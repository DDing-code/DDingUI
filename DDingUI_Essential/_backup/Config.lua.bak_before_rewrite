------------------------------------------------------------------------
local function CreateConfigPanel()
    if panel then return panel end

    -- StyleLib 재확인 -- [ESSENTIAL-DESIGN]
    if not ns.SL then
        local sl = _G.DDingUI_StyleLib
        if sl then
            ns.SL = sl
            ns.FLAT = sl.Textures and sl.Textures.flat or ns.FLAT
            ns.FONT = sl.Font and sl.Font.path or ns.FONT
        end
    end

    local SL = ns.SL
    if not SL then
        -- StyleLib 없을 때 폴백 메시지 -- [ESSENTIAL-DESIGN]
        local f = CreateFrame("Frame", "DDingUIEssentialConfig", UIParent, BackdropTemplateMixin and "BackdropTemplate" or nil)
        f:SetSize(300, 100)
        f:SetPoint("CENTER")
        f:SetFrameStrata("DIALOG")
        f:Hide()

        if f.SetBackdrop then
            f:SetBackdrop({
                bgFile = "Interface\\Buttons\\WHITE8x8",
                edgeFile = "Interface\\Buttons\\WHITE8x8",
                edgeSize = 1,
            })
            f:SetBackdropColor(0.1, 0.1, 0.1, 0.95)
            f:SetBackdropBorderColor(0, 0, 0, 1)
        end

        local msg = f:CreateFontString(nil, "OVERLAY")
        msg:SetFont("Fonts\\2002.TTF", 13, "")
        msg:SetPoint("CENTER")
        msg:SetText("|cffff5555DDingUI_StyleLib\236\157\180 \237\149\132\236\154\148\237\149\169\235\139\136\235\139\164.|r")

        local closeBtn = CreateFrame("Button", nil, f)
        closeBtn:SetSize(20, 20)
        closeBtn:SetPoint("TOPRIGHT", -4, -4)
        local closeText = closeBtn:CreateFontString(nil, "OVERLAY")
        closeText:SetFont("Fonts\\FRIZQT__.TTF", 12, "OUTLINE")
        closeText:SetPoint("CENTER")
        closeText:SetText("X")
        closeText:SetTextColor(0.8, 0.8, 0.8)
        closeBtn:SetScript("OnClick", function() f:Hide() end)

        tinsert(UISpecialFrames, "DDingUIEssentialConfig")
        panel = { frame = f }
        return panel
    end

    -- CDM/UF 동일 규격 패널 -- [ESSENTIAL-DESIGN]
    local version = C_AddOns and C_AddOns.GetAddOnMetadata and C_AddOns.GetAddOnMetadata("DDingUI_Essential", "Version") or "0.3.0"
    panel = SL.CreateSettingsPanel("Essential", "DDing Essential", version, {
        width = 920,              -- CDM/UF 동일 -- [ESSENTIAL-DESIGN]
        height = 620,             -- CDM/UF 동일 -- [ESSENTIAL-DESIGN]
        minWidth = 600,
        minHeight = 400,
        menuWidth = 200,          -- CDM/UF 동일 -- [ESSENTIAL-DESIGN]
    })

    -- 프레임 테두리 솔리드 블랙 (CDM 통일) -- [ESSENTIAL-DESIGN]
    panel.frame:SetBackdropBorderColor(0, 0, 0, 1)

    -- 트리 메뉴 생성 -- [ESSENTIAL-DESIGN]
    treeMenu = SL.CreateTreeMenu(panel.treeFrame, ADDON_NAME, MENU_DATA, {
        defaultKey = "minimap",
        onSelect = function(key)
            ShowPage(key)
        end,
    })

    -- 패널 보일 때마다 트리 메뉴 강제 리프레시 -- [ESSENTIAL-DESIGN]
    panel.frame:HookScript("OnShow", function()
        if treeMenu then
            treeMenu:SetMenuData(MENU_DATA)
            treeMenu:SetSelected(treeMenu:GetSelected() or "minimap")
        end
        ShowPage(treeMenu and treeMenu:GetSelected() or "minimap")
    end)

    return panel
end

