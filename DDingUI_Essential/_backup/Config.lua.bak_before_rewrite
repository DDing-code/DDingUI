------------------------------------------------------------------------
-- 위젯 레이아웃 헬퍼 -- [ESSENTIAL-DESIGN]
------------------------------------------------------------------------
local WIDGET_GAP = 6   -- 위젯 간 수직 간격 (CDM 통일)

local function LayoutY(page, widgets)
    local yOff = 0
    for _, w in ipairs(widgets) do
        w:ClearAllPoints()
        w:SetPoint("TOPLEFT", page, "TOPLEFT", 0, -yOff)
        w:SetPoint("RIGHT", page, "RIGHT", 0, 0)
        yOff = yOff + (w:GetHeight() or 24) + WIDGET_GAP
    end
    local totalH = math.max(yOff + 30, 400)
    page:SetHeight(totalH)
    -- 스크롤 영역 높이 동기화 (contentChild) -- [ESSENTIAL-DESIGN]
    local parent = page:GetParent()
    if parent and parent.SetHeight then
        parent:SetHeight(totalH + 24)
    end
end

------------------------------------------------------------------------
-- 모듈 비활성 시 위젯 회색 처리 -- [ESSENTIAL-DESIGN]
------------------------------------------------------------------------
local function SetWidgetsEnabled(key, enabled)
    local mw = moduleWidgets[key]
    if not mw then return end
    for _, w in ipairs(mw.widgets) do
        w:SetAlpha(enabled and 1.0 or 0.5)
        w:EnableMouse(enabled)
        -- 자식 프레임도 비활성 처리 -- [ESSENTIAL-DESIGN]
        local children = { w:GetChildren() }
        for _, child in ipairs(children) do
            if child.SetEnabled then
                child:SetEnabled(enabled)
            end
            child:EnableMouse(enabled)
        end
    end
end

------------------------------------------------------------------------
-- 모듈 토글 헬퍼 -- [ESSENTIAL-DESIGN]
------------------------------------------------------------------------
local function ModuleToggle(dbKey, val, label)
    if ns.db and ns.db[dbKey] then
        ns.db[dbKey].enabled = val
        if val then
            ns:EnableModule(dbKey)
        else
            ns:DisableModule(dbKey)
        end
        SetWidgetsEnabled(dbKey, val)
        -- 하위 페이지 위젯도 전파 (CDM/UF 패턴) -- [ESSENTIAL-DESIGN]
        for childKey, _ in pairs(moduleWidgets) do
            if childKey:find(dbKey .. ".", 1, true) then
                SetWidgetsEnabled(childKey, val)
            end
        end
    end
end

------------------------------------------------------------------------
-- 카테고리 초기화 버튼 헬퍼 -- [ESSENTIAL-DESIGN]
------------------------------------------------------------------------
local function CreateResetButton(page, SL, dbKey, defaultsTable, rebuildFunc)
    return SL.CreateButton(page, ADDON_NAME, "초기화", function()
        if ns.db and defaultsTable then
            for k, v in pairs(defaultsTable) do
                if type(v) == "table" then
                    ns.db[dbKey][k] = CopyTable(v)
                else
                    ns.db[dbKey][k] = v
                end
            end
            -- 페이지 재빌드 -- [ESSENTIAL-DESIGN]
            if pageFrames[dbKey] then
                pageFrames[dbKey]:Hide()
                pageFrames[dbKey] = nil
                moduleWidgets[dbKey] = nil
            end
            if rebuildFunc then
                local newPage = CreateFrame("Frame", nil, panel.contentChild)
                newPage:SetPoint("TOPLEFT", 16, -12)
                newPage:SetPoint("TOPRIGHT", -16, -12)
                newPage:SetHeight(600)
                pageFrames[dbKey] = newPage
                rebuildFunc(newPage)
                newPage:Show()
            end
            print("|cffffd133DDingUI Essential:|r " .. dbKey .. " 설정이 초기화되었습니다. /reload 권장") -- [ESSENTIAL-DESIGN]
        end
    end, { width = 80, height = 24 })
end

------------------------------------------------------------------------
-- 페이지 전환 -- [ESSENTIAL-DESIGN]
------------------------------------------------------------------------
local function ShowPage(key)
    for _, p in pairs(pageFrames) do p:Hide() end

    -- StyleLib 재확인 (지연 로드 대응) -- [ESSENTIAL-DESIGN]
    if not ns.SL then
        local sl = _G.DDingUI_StyleLib
        if sl then
            ns.SL = sl
            ns.FLAT = sl.Textures and sl.Textures.flat or ns.FLAT
            ns.FONT = sl.Font and sl.Font.path or ns.FONT
        end
    end

    local page = pageFrames[key]
    if not page or (page._deEmpty and ns.SL) then
        if page then page:Hide() end
        page = CreateFrame("Frame", nil, panel.contentChild)
        page:SetPoint("TOPLEFT", 16, -12)
        page:SetPoint("TOPRIGHT", -16, -12)
        page:SetHeight(600)
        pageFrames[key] = page

        if pageBuilders[key] then
            pageBuilders[key](page)
            if not ns.SL then
                page._deEmpty = true
            end
        end
    end
    page:Show()
end

