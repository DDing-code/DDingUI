SLASH_DDINGUIESSENTIAL1 = "/des"
SLASH_DDINGUIESSENTIAL2 = "/ddessential"

SlashCmdList["DDINGUIESSENTIAL"] = function()
    local p = CreateConfigPanel()
    if p and p.frame then
        if p.frame:IsShown() then
            p.frame:Hide()
        else
            p.frame:Show()
        end
    end
end
