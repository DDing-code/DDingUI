local _, ns = ...

------------------------------------------------------------------------
-- 패널 상태 -- [ESSENTIAL]
------------------------------------------------------------------------
local panel        -- CreateSettingsPanel 결과 테이블
local treeMenu     -- CreateTreeMenu 결과
local pageFrames = {} -- key → page frame 캐시
local pageBuilders = {} -- key → builder function

------------------------------------------------------------------------
-- 트리 메뉴 데이터 -- [ESSENTIAL]
------------------------------------------------------------------------
local MENU_DATA = {
    { text = "일반 설정",      key = "general" },
    { text = "미니맵",         key = "minimap" },
    { text = "채팅",           key = "chat" },
    { text = "버프/디버프",    key = "buffs" },
    { text = "퀘스트 추적기",  key = "quest" },
