-- 패널 생성 -- [ESSENTIAL]
------------------------------------------------------------------------
local function CreateConfigPanel()
    if panel then return panel end

    -- StyleLib 재확인 (지연 로드 대응) -- [ESSENTIAL]
    if not ns.SL then
        local sl = _G.DDingUI_StyleLib
        if sl then
            ns.SL = sl
            ns.FLAT = sl.Textures and sl.Textures.flat or ns.FLAT
            ns.FONT = sl.Font and sl.Font.path or ns.FONT
        end
    end

    local SL = ns.SL
    if not SL then
        -- StyleLib 없을 때 폴백 메시지 -- [ESSENTIAL]
        local f = CreateFrame("Frame", "DDingUIEssentialConfig", UIParent, BackdropTemplateMixin and "BackdropTemplate" or nil)
        f:SetSize(300, 100)
        f:SetPoint("CENTER")
        f:SetFrameStrata("DIALOG")
        f:Hide()

        if f.SetBackdrop then
            f:SetBackdrop({
                bgFile = "Interface\\Buttons\\WHITE8x8",
                edgeFile = "Interface\\Buttons\\WHITE8x8",
                edgeSize = 1,
            })
            f:SetBackdropColor(0.1, 0.1, 0.1, 0.95)
            f:SetBackdropBorderColor(0, 0, 0, 1)
        end

        local msg = f:CreateFontString(nil, "OVERLAY")
        msg:SetFont("Fonts\\2002.TTF", 13, "")
        msg:SetPoint("CENTER")
        msg:SetText("|cffff5555DDingUI_StyleLib\236\157\180 \237\149\132\236\154\148\237\149\169\235\139\136\235\139\164.|r\n|cff888888\236\149\160\235\147\156\236\152\168 \235\170\169\235\161\157\236\151\144\236\132\156 \237\153\156\236\132\177\237\153\148 \237\155\132 /reload \237\149\180\236\163\188\236\132\184\236\154\148.|r")

        local closeBtn = CreateFrame("Button", nil, f)
        closeBtn:SetSize(20, 20)
        closeBtn:SetPoint("TOPRIGHT", -4, -4)
        local closeText = closeBtn:CreateFontString(nil, "OVERLAY")
        closeText:SetFont("Fonts\\FRIZQT__.TTF", 12, "OUTLINE")
        closeText:SetPoint("CENTER")
        closeText:SetText("X")
        closeText:SetTextColor(0.8, 0.8, 0.8)
        closeBtn:SetScript("OnClick", function() f:Hide() end)

        tinsert(UISpecialFrames, "DDingUIEssentialConfig")
        panel = { frame = f }
        return panel
    end

    -- StyleLib CreateSettingsPanel 사용 -- [ESSENTIAL]
    local version = C_AddOns and C_AddOns.GetAddOnMetadata and C_AddOns.GetAddOnMetadata("DDingUI_Essential", "Version") or ""
    panel = SL.CreateSettingsPanel("Essential", "DDingUI Essential", version or "1.0", {
        width = 700,
        height = 500,
        minWidth = 600,
        minHeight = 400,
        menuWidth = 180,
    })

    -- 트리 메뉴 생성 -- [ESSENTIAL]
    treeMenu = SL.CreateTreeMenu(panel.treeFrame, "Essential", MENU_DATA, {
        defaultKey = "general",
        onSelect = function(key)
            ShowPage(key)
        end,
    })

    -- [BUGFIX] 패널이 보일 때마다 트리 메뉴 강제 리프레시 -- [ESSENTIAL]
    -- CreateTreeMenu 내부 C_Timer.After(0) 초기 렌더링이 패널 숨김 상태에서 실행되어
    -- 버튼 크기가 0/1px이 됨. OnShow 시 SetMenuData로 강제 재렌더링.
    panel.frame:HookScript("OnShow", function()
        if treeMenu then
            treeMenu:SetMenuData(MENU_DATA)
            treeMenu:SetSelected(treeMenu:GetSelected() or "general")
        end
        ShowPage(treeMenu and treeMenu:GetSelected() or "general")
    end)

    return panel
end

