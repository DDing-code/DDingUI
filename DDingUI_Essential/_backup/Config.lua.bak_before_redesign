}

------------------------------------------------------------------------
-- 위젯 레이아웃 헬퍼 -- [ESSENTIAL]
------------------------------------------------------------------------
local WIDGET_GAP = 6   -- 위젯 간 수직 간격
local SECTION_GAP = 14 -- 섹션 헤더 전 추가 간격

local function LayoutY(page, widgets)
    local yOff = 0
    for _, w in ipairs(widgets) do
        w:ClearAllPoints()
        w:SetPoint("TOPLEFT", page, "TOPLEFT", 0, -yOff)
        w:SetPoint("RIGHT", page, "RIGHT", 0, 0)
        yOff = yOff + (w:GetHeight() or 24) + WIDGET_GAP
    end
    page:SetHeight(math.max(yOff + 30, 400))
end

------------------------------------------------------------------------
-- 설명 텍스트 헬퍼 -- [ESSENTIAL]
------------------------------------------------------------------------
local function CreateDescription(parent, text)
    local SL = ns.SL
    local f = CreateFrame("Frame", nil, parent)
    f:SetHeight(16)
    local fs = f:CreateFontString(nil, "OVERLAY")
    fs:SetFont(ns.FONT, (SL and SL.Font and SL.Font.small) or 11, "")
    fs:SetPoint("TOPLEFT", 0, 0)
    fs:SetPoint("RIGHT", f, "RIGHT", 0, 0)
    fs:SetJustifyH("LEFT")
    fs:SetText("|cff888888" .. text .. "|r")
    fs:SetShadowOffset(1, -1)
    return f
end

------------------------------------------------------------------------
-- 페이지 전환 -- [ESSENTIAL]
------------------------------------------------------------------------
local function ShowPage(key)
    for _, p in pairs(pageFrames) do p:Hide() end

    -- StyleLib 재확인 (지연 로드 대응) -- [ESSENTIAL]
    if not ns.SL then
        local sl = _G.DDingUI_StyleLib
        if sl then
            ns.SL = sl
            ns.FLAT = sl.Textures and sl.Textures.flat or ns.FLAT
            ns.FONT = sl.Font and sl.Font.path or ns.FONT
        end
    end

    local page = pageFrames[key]
    -- 페이지가 없거나, 이전에 SL 없이 빈 상태로 빌드된 경우 재빌드 -- [ESSENTIAL]
    if not page or (page._deEmpty and ns.SL) then
        if page then page:Hide() end
        page = CreateFrame("Frame", nil, panel.contentChild)
        page:SetPoint("TOPLEFT", 16, -12)
        page:SetPoint("TOPRIGHT", -16, -12)
        page:SetHeight(600)
        pageFrames[key] = page

        if pageBuilders[key] then
            pageBuilders[key](page)
            -- SL 없이 빌드된 경우 표시 -- [ESSENTIAL]
            if not ns.SL then
                page._deEmpty = true
            end
        end
    end
    page:Show()
end

