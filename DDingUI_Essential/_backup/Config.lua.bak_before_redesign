pageBuilders["general"] = function(page)
    local SL = ns.SL
    if not SL then return end

    local widgets = {}

    -- 섹션: 모듈 활성화 -- [ESSENTIAL]
    local secModules = SL.CreateSectionHeader(page, "Essential", "모듈 활성화", { isFirst = true })
    widgets[#widgets + 1] = secModules

    widgets[#widgets + 1] = CreateDescription(page, "각 모듈을 개별적으로 활성화/비활성화할 수 있습니다.")

    local MODULE_INFO = {
        { key = "minimap",    label = "미니맵 스킨" },
        { key = "chat",       label = "채팅 스킨" },
        { key = "buffs",      label = "버프/디버프 스킨" },
        { key = "quest",      label = "퀘스트 추적기 스킨" },
        { key = "meter",      label = "데미지미터 스킨" },
        { key = "actionbars", label = "행동 단축바 스킨" },
    }

    for _, info in ipairs(MODULE_INFO) do
        local dbKey = info.key
        local currentVal = ns.db and ns.db[dbKey] and ns.db[dbKey].enabled ~= false
        local cb = SL.CreateCheckbox(page, "Essential", info.label, currentVal, {
            onChange = function(val)
                if ns.db and ns.db[dbKey] then
                    ns.db[dbKey].enabled = val
                    if val then
                        ns:EnableModule(dbKey)
                    else
                        ns:DisableModule(dbKey)
                    end
                    print("|cff40e0d0DDingUI Essential:|r " .. info.label .. (val and " |cff00ff00활성화|r" or " |cffff0000비활성화|r") .. " (완전 적용: /reload)")
                end
            end,
        })
        widgets[#widgets + 1] = cb
    end

    -- 섹션: 전체 설정 -- [ESSENTIAL]
    local secGeneral = SL.CreateSectionHeader(page, "Essential", "전체 설정")
    widgets[#widgets + 1] = secGeneral

    -- UI 스케일 슬라이더 -- [ESSENTIAL]
    local scaleVal = ns.db and ns.db.general and ns.db.general.scale or 1.0
    local scaleSlider = SL.CreateSlider(page, "Essential", "UI 스케일", 0.5, 1.5, 0.05, scaleVal, {
        width = 300,
        onChange = function(val)
            if ns.db and ns.db.general then
                ns.db.general.scale = val
            end
        end,
    })
    widgets[#widgets + 1] = scaleSlider

    -- ReloadUI 버튼 -- [ESSENTIAL]
    local reloadBtn = SL.CreateButton(page, "Essential", "UI 새로고침 (ReloadUI)", function()
        ReloadUI()
    end, { width = 180, height = 28 })
    widgets[#widgets + 1] = reloadBtn

    -- 안내 텍스트 -- [ESSENTIAL]
    widgets[#widgets + 1] = CreateDescription(page, "* 대부분의 설정은 /reload 후 적용됩니다")

    LayoutY(page, widgets)
end

